#!/bin/sh
#
# pre-commit hook for notification-mcp
#
# Runs type checking and unit tests before allowing a commit.
# Install: npm run hooks:install
#

set -e

echo "pre-commit: type checking..." >&2
npx tsc --noEmit >&2

echo "pre-commit: unit tests..." >&2
npx vitest run tests/unit >&2

echo "pre-commit: passed" >&2
