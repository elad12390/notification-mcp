#!/bin/sh
#
# pre-push hook for notification-mcp
#
# Runs type checking, unit tests, and BDD scenarios before allowing a push.
# Real-TTS integration tests are skipped (they take 60s+ and play audio).
# Run `npm run test:all` for the full suite including integration tests.
#
# Install: npm run hooks:install
#

set -e

echo "pre-push: type checking..." >&2
npx tsc --noEmit >&2

echo "pre-push: unit tests..." >&2
npx vitest run tests/unit >&2

echo "pre-push: BDD scenarios..." >&2
NODE_OPTIONS='--import tsx' npx cucumber-js >&2

echo "pre-push: all checks passed" >&2
